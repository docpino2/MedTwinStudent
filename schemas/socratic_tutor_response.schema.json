{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medtwin.student/schemas/socratic_tutor_response.schema.json",
  "title": "MedTwin Student Socratic Tutor Response",
  "type": "object",
  "required": [
    "teaching_style",
    "intent",
    "should_withhold_final_answer",
    "tutor_question",
    "rationale_for_question",
    "detected_knowledge_gaps",
    "detected_biases",
    "rubric_feedback",
    "suggested_tool_calls",
    "stop_condition"
  ],
  "additionalProperties": false,
  "properties": {
    "teaching_style": {
      "type": "string",
      "enum": ["basic_sciences", "clinical_sciences", "internship"]
    },
    "intent": {
      "type": "string",
      "enum": [
        "elicit_problem_representation",
        "probe_mechanism",
        "probe_differential",
        "probe_data_interpretation",
        "probe_management",
        "probe_safety",
        "probe_reflection"
      ]
    },
    "should_withhold_final_answer": {
      "type": "boolean",
      "const": true
    },
    "tutor_question": {
      "type": "string",
      "minLength": 12
    },
    "rationale_for_question": {
      "type": "string"
    },
    "detected_knowledge_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["concept_id", "label", "severity", "evidence"],
        "additionalProperties": false,
        "properties": {
          "concept_id": { "type": "string" },
          "label": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "moderate", "high"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "detected_biases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bias", "risk_level", "evidence", "debiasing_move"],
        "additionalProperties": false,
        "properties": {
          "bias": { "type": "string" },
          "risk_level": { "type": "string", "enum": ["low", "moderate", "high"] },
          "evidence": { "type": "string" },
          "debiasing_move": { "type": "string" }
        }
      }
    },
    "rubric_feedback": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion", "score", "rationale", "next_step"],
        "additionalProperties": false,
        "properties": {
          "criterion": { "type": "string" },
          "score": { "type": "integer", "minimum": 0, "maximum": 4 },
          "rationale": { "type": "string" },
          "next_step": { "type": "string" }
        }
      }
    },
    "suggested_tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_name", "purpose", "inputs"],
        "additionalProperties": false,
        "properties": {
          "tool_name": { "type": "string" },
          "purpose": { "type": "string" },
          "inputs": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "stop_condition": {
      "type": "string"
    }
  }
}

